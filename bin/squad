#!/usr/bin/env bash
set -euo pipefail

# ╔══════════════════════════════════════════════════════════════╗
# ║  Claude Squad — Multi-Agent Development Harness              ║
# ║  GAN-style Planner → Generator → Evaluator orchestration     ║
# ║  using tmux + Claude Code + Playwright                       ║
# ╚══════════════════════════════════════════════════════════════╝

SQUAD_VERSION="1.0.0"
SQUAD_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Capture env-set squad name (if any) before sourcing libs.
# lib/tmux.sh defaults SQUAD_NAME to "default" when unset, which would
# otherwise make "unset" indistinguishable from "set to default".
SQUAD_NAME_FROM_ENV="${SQUAD_NAME:-}"

# Source libraries
source "${SQUAD_DIR}/lib/tmux.sh"
source "${SQUAD_DIR}/lib/mailbox.sh"
source "${SQUAD_DIR}/lib/worktree.sh"
source "${SQUAD_DIR}/lib/harness.sh"
source "${SQUAD_DIR}/lib/monitor.sh"
source "${SQUAD_DIR}/lib/prompt.sh"
source "${SQUAD_DIR}/lib/registry.sh"
source "${SQUAD_DIR}/lib/archive.sh"

# ─── Defaults ────────────────────────────────────────────────────

# Legacy fixed-roster boot uses these when --static is passed.
DEFAULT_STATIC_ROLES="coder,tester"
REPO_PATH="$(pwd)"

# ─── Helpers ─────────────────────────────────────────────────────

usage() {
  cat << 'EOF'
Claude Squad — Multi-Agent Development Harness

USAGE:
  squad <command> [options]

COMMANDS:
  start [sprint.md]    Launch a planner-only tmux session (dynamic by default)
  stop                 Kill the tmux session and archive the runtime for resume
                       Flags: [--no-archive] [--nuke-worktrees]
  resume [name]        Restore the latest archive of <name> and respawn each
                       agent with their Claude conversation resumed
                       Flags: [--fresh] [--no-restore-claude]
  archive list         Show all archived squads in this repo (newest first)
  archive prune        Delete archives older than the retention window
                       Flags: [--older-than 30d]
  archive rm <dir>     Delete a specific archive
  status               Show agent status dashboard
  watch                Live-updating status dashboard
  attach               Attach to the tmux session
  roles                List available roles
  roster               Show the live agent registry as a markdown table
  list                 List all squads in the current repo (alias: ls)
  use <name>           Make a squad the current one for subsequent commands
  spawn <role>         Spawn a new agent pane at runtime (e.g. coder, tester)
                       Flags: [--instance N] [--worktree|--no-worktree]
                              [--model M] [--fresh]
  kill <name>          Gracefully retire an agent (soft kill + grace window)
                       Flags: [--hard] [--grace-seconds N]
  doctor               Reconcile registry vs tmux; flip orphans to vanished
  usage <name>         Print agent's token/time/mailbox usage as JSON
                       (signal for the planner; does not interpret values)
  recycle <name>       kill + spawn the same agent in one verb (preserves
                       Claude session unless --fresh). Convenience for the
                       planner when an agent needs a context refresh.
                       Flags: [--reason "..."] [--grace-seconds N] [--fresh]
  mail <to> <type> <body...>  Send a mailbox message and nudge recipient pane
  inbox                Show mail addressed to you (or to "all")
                       Flags: [--since <iso>] [--all] [--name <override>]
  init                 Copy sprint template to ./sprints/
  harness <prompt>     Run headless GAN-style harness (no tmux)
  merge <role>         Merge a role's worktree branch back to main

OPTIONS:
  --name <squad>       Target a specific squad. Defaults to .squad/current,
                       SQUAD_NAME env var, or "default". Lets multiple squads
                       run in parallel in the same repo.
  --static <r1,r2,...> Legacy fixed-roster boot (default: coder,tester).
                       Without this flag, squad start boots only the planner;
                       additional agents are spawned at runtime.
  --repo <path>        Target repository (default: current directory)
  --worktrees          Use git worktrees for agent isolation
  --model <model>      Model to use (default: claude-opus-4-6)

EXAMPLES:
  squad start                              # planner-only dynamic boot (squad 'default')
  squad start --name backend               # second parallel squad in same repo
  squad start sprints/feature.md           # planner with a sprint file
  squad start --static coder,tester        # legacy fixed roster
  squad start --static planner,coder,tester --worktrees
  squad stop                               # archives runtime to .squad-archive/
  squad resume                             # resumes the latest 'default' archive
  squad resume backend                     # resumes the latest 'backend' archive
  squad archive list                       # see archived squads (within ${SQUAD_ARCHIVE_RETENTION_DAYS:-30}d)
  squad list                               # see all live squads in this repo
  squad use backend                        # switch current squad
  squad attach --name backend              # attach to a specific squad
  squad harness "Build a todo app"         # headless harness loop
  squad status                             # check current squad's agent progress

EOF
}

generate_session_id() {
  date +%s | shasum | head -c 8
}

validate_role() {
  local role="${1:-}"
  [[ -f "${SQUAD_DIR}/roles/${role}.md" ]]
}

# ─── Squad name resolution ───────────────────────────────────────
# Multiple squads can run in parallel in the same repo. Each squad has:
#   - a tmux session     "claude-squad-${SQUAD_NAME}"
#   - a runtime dir      "${REPO_PATH}/.squad/${SQUAD_NAME}/"
#
# Priority: explicit --name flag > $SQUAD_NAME env > .squad/current pointer
# > "default". Commands that mutate which squad is "current" (start) write
# the .squad/current pointer so subsequent commands inherit the name without
# the user re-typing it.

# Strip the --name flag (and its value) from "$@" and echo the value, if any.
# Usage: name=$(_extract_name_flag "$@")
_extract_name_flag() {
  local out=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) out="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  echo "$out"
}

# Re-build "$@" with the --name flag removed. Echoes one arg per line so the
# caller can do: mapfile -t args < <(_strip_name_flag "$@")
_strip_name_flag() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) shift 2 ;;
      *) printf '%s\n' "$1"; shift ;;
    esac
  done
}

# Resolve the active squad name for a command that READS state (everything
# except `start`). Returns 0 on success; exits 1 if no squad is active and
# no fallback can be derived.
#
# Usage: _resolve_squad_name "$@"  (pass through the original argv so the
# helper can see a --name flag if you gave one)
_resolve_squad_name() {
  local from_flag
  from_flag=$(_extract_name_flag "$@")

  if [[ -n "$from_flag" ]]; then
    SQUAD_NAME="$from_flag"
  elif [[ -n "$SQUAD_NAME_FROM_ENV" ]]; then
    SQUAD_NAME="$SQUAD_NAME_FROM_ENV"
  elif [[ -f "${REPO_PATH}/.squad/current" ]]; then
    SQUAD_NAME=$(<"${REPO_PATH}/.squad/current")
  else
    SQUAD_NAME="default"
  fi

  export SQUAD_NAME
  squad_tmux_set_session_name
}

# For `squad start`. Same priority order, but writes .squad/current after
# resolving so subsequent commands inherit the name.
_resolve_and_persist_squad_name() {
  _resolve_squad_name "$@"
  mkdir -p "${REPO_PATH}/.squad"
  printf '%s\n' "$SQUAD_NAME" > "${REPO_PATH}/.squad/current"
}

# Per-squad runtime dir. Use AFTER _resolve_squad_name (or
# _resolve_and_persist_squad_name) has set SQUAD_NAME.
_squad_runtime() {
  echo "${REPO_PATH}/.squad/${SQUAD_NAME}"
}

# ─── Commands ────────────────────────────────────────────────────

cmd_start() {
  local sprint_file=""
  local static_roles=""
  local use_worktrees=false
  local model="claude-opus-4-6"
  local name_flag=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name_flag="$2"
        shift 2
        ;;
      --static)
        static_roles="$2"
        shift 2
        ;;
      --roles)
        # Legacy alias for --static, preserved for any existing scripts/docs.
        static_roles="$2"
        shift 2
        ;;
      --repo)
        REPO_PATH="$(cd "$2" && pwd)"
        shift 2
        ;;
      --worktrees)
        use_worktrees=true
        shift
        ;;
      --model)
        model="$2"
        shift 2
        ;;
      -*)
        echo "Unknown option: $1" >&2
        exit 1
        ;;
      *)
        sprint_file="$1"
        shift
        ;;
    esac
  done

  # Resolve the squad name BEFORE checking session existence, so the check is
  # scoped to the right session. Persist the chosen name to .squad/current so
  # `squad spawn`, `squad attach` etc. inherit it without --name.
  if [[ -n "$name_flag" ]]; then
    _resolve_and_persist_squad_name --name "$name_flag"
  else
    _resolve_and_persist_squad_name
  fi

  if [[ -n "$sprint_file" ]] && [[ ! -f "$sprint_file" ]]; then
    echo "Error: sprint file not found: $sprint_file" >&2
    exit 1
  fi
  if [[ -n "$sprint_file" ]]; then
    sprint_file="$(cd "$(dirname "$sprint_file")" && pwd)/$(basename "$sprint_file")"
  fi

  if tmux has-session -t "$SQUAD_SESSION" 2>/dev/null; then
    echo "Error: squad '${SQUAD_NAME}' is already running (tmux session '$SQUAD_SESSION')." >&2
    echo "       Run 'squad stop --name ${SQUAD_NAME}' first, or start a different squad with --name <other>." >&2
    exit 1
  fi

  if [[ -n "$static_roles" ]]; then
    _cmd_start_static "$sprint_file" "$static_roles" "$use_worktrees" "$model"
  else
    _cmd_start_dynamic "$sprint_file" "$use_worktrees" "$model"
  fi
}

# Default boot: a single planner pane. Additional agents spawn at runtime.
_cmd_start_dynamic() {
  local sprint_file="$1"
  local use_worktrees="$2"
  local model="$3"

  echo "╔══════════════════════════════════════════════════════╗"
  echo "║  Claude Squad v${SQUAD_VERSION}                               ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo ""
  echo "Squad:      ${SQUAD_NAME}  (tmux session '${SQUAD_SESSION}')"
  echo "Mode:       dynamic (planner-only boot; spawn peers with 'squad spawn <role>')"
  echo "Repo:       $REPO_PATH"
  echo "Sprint:     ${sprint_file:-none}"
  echo "Worktrees:  $use_worktrees"
  echo "Model:      $model"
  echo ""

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  mkdir -p "$squad_runtime"

  local session_id
  session_id=$(generate_session_id)

  squad_registry_init "$squad_runtime" "$session_id" "$REPO_PATH" "$model" "$sprint_file" "$use_worktrees" >/dev/null
  squad_mailbox_init "$squad_runtime" >/dev/null

  local planner_workdir="$REPO_PATH"
  local planner_wt=""
  if [[ "$use_worktrees" == "true" ]]; then
    echo "Creating worktree for planner..."
    planner_wt=$(squad_worktree_create "$REPO_PATH" "planner" "$session_id")
    if [[ -n "$planner_wt" ]] && [[ -d "$planner_wt" ]]; then
      planner_workdir="$planner_wt"
      echo "  planner → $planner_wt"
      echo ""
    else
      echo "  Warning: failed to create worktree for planner" >&2
    fi
  fi

  echo "Generating planner prompt..."
  local planner_claude_sid
  planner_claude_sid=$(uuidgen | tr 'A-Z' 'a-z')
  squad_prompt_generate_dynamic "$squad_runtime" "planner" "planner" "$planner_workdir" "$sprint_file" >/dev/null
  squad_prompt_launcher_dynamic "$squad_runtime" "planner" "$planner_workdir" "$model" "$planner_claude_sid" "0" >/dev/null
  echo "  Wrote prompt-planner.md and launch-planner.sh (claude session ${planner_claude_sid})"
  echo ""

  echo "Creating tmux session..."
  local pane_id
  pane_id=$(squad_tmux_create_single_pane "planner" 1)
  echo "  planner pane: $pane_id"
  echo ""

  local agent_json
  agent_json=$(jq -n \
    --arg role "planner" --argjson instance 1 --arg name "planner" \
    --arg pane_id "$pane_id" --arg wt "$planner_wt" --arg model "$model" \
    --arg claude_sid "$planner_claude_sid" \
    --arg spawned_at "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
    '{role:$role, instance:$instance, name:$name, pane_id:$pane_id,
      worktree_path:$wt, model:$model, claude_session_id:$claude_sid,
      spawned_at:$spawned_at, status:"alive"}')
  squad_registry_add "$squad_runtime" "$agent_json"

  echo "Launching planner..."
  squad_tmux_launch_pane "$pane_id" "bash ${squad_runtime}/launch-planner.sh"
  echo "  planner launched"
  echo ""

  # No kick-off prompt is injected. The harness boots the planner with its
  # system prompt; the first user turn (you, typing into the pane) is the
  # brief. This keeps the harness mechanism-only — no policy in CLI strings.
  echo "Waiting for Claude Code to initialize..."
  sleep 4
  echo ""

  _attach_or_hint
}

# Attach to the squad session if we're in a terminal; otherwise print a hint.
# tmux refuses to attach when stdin is not a tty or when already inside tmux.
_attach_or_hint() {
  if [[ -n "${TMUX:-}" ]]; then
    echo "Already inside a tmux session — run 'squad attach' from a fresh terminal,"
    echo "or detach this tmux (Ctrl+B then d) and re-run 'squad attach'."
    return 0
  fi
  if [[ ! -t 0 ]] || [[ ! -t 1 ]]; then
    echo "Squad is running detached. Run 'squad attach' to jump in."
    return 0
  fi
  echo "Attaching… (Ctrl+B then d to detach; 'squad attach' to re-join later)"
  exec tmux attach-session -t "$SQUAD_SESSION"
}

# Legacy fixed-roster boot. Unchanged behavior, preserved behind --static.
_cmd_start_static() {
  local sprint_file="$1"
  local roles_str="$2"
  local use_worktrees="$3"
  local model="$4"

  IFS=',' read -ra roles <<< "$roles_str"

  for role in "${roles[@]}"; do
    if ! validate_role "$role"; then
      echo "Error: unknown role '$role'. Run 'squad roles' to see available roles." >&2
      exit 1
    fi
  done

  echo "╔══════════════════════════════════════════════════════╗"
  echo "║  Claude Squad v${SQUAD_VERSION}                               ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo ""
  echo "Squad:      ${SQUAD_NAME}  (tmux session '${SQUAD_SESSION}')"
  echo "Mode:       static (legacy fixed roster)"
  echo "Repo:       $REPO_PATH"
  echo "Roles:      ${roles[*]}"
  echo "Sprint:     ${sprint_file:-none}"
  echo "Worktrees:  $use_worktrees"
  echo "Model:      $model"
  echo ""

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  mkdir -p "$squad_runtime"

  local session_id
  session_id=$(generate_session_id)

  local roles_json="["
  for ((i = 0; i < ${#roles[@]}; i++)); do
    [[ $i -gt 0 ]] && roles_json+=","
    roles_json+="\"${roles[$i]}\""
  done
  roles_json+="]"

  cat > "${squad_runtime}/session.json" << HEREDOC
{
  "session_id": "${session_id}",
  "roles": ${roles_json},
  "repo_path": "${REPO_PATH}",
  "sprint_file": "${sprint_file}",
  "use_worktrees": ${use_worktrees},
  "model": "${model}",
  "start_time": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "agents": []
}
HEREDOC

  squad_mailbox_init "$squad_runtime" >/dev/null

  if [[ "$use_worktrees" == "true" ]]; then
    echo "Creating git worktrees for agent isolation..."
    local _wt_path
    for role in "${roles[@]}"; do
      _wt_path=$(squad_worktree_create "$REPO_PATH" "$role" "$session_id")
      if [[ -n "$_wt_path" ]] && [[ -d "$_wt_path" ]]; then
        echo "  $role → $_wt_path"
      else
        echo "  Warning: failed to create worktree for $role" >&2
      fi
    done
    echo ""
  fi

  echo "Generating agent prompts..."
  squad_prompt_generate_all "$squad_runtime" "$REPO_PATH" "$sprint_file" "$model" "${roles[@]}" >/dev/null
  echo "  Generated prompts and launchers for: ${roles[*]}"
  echo ""

  echo "Creating tmux session..."
  squad_tmux_create_session "${roles[@]}"
  echo ""

  echo "Launching agents..."
  for ((i = 0; i < ${#roles[@]}; i++)); do
    local role="${roles[$i]}"
    local launch_file="${squad_runtime}/launch-${role}.sh"
    if [[ -f "$launch_file" ]]; then
      squad_tmux_launch "$i" "bash ${launch_file}"
      echo "  Pane $i: $role launched"
    else
      echo "  Warning: no launcher for $role" >&2
    fi
  done

  # No per-role kick-off prompts. Agents boot with their system prompt and
  # wait for instruction — from the user (typing in a pane) or from peers
  # (via mailbox). The harness mechanism does not prescribe their first move.
  echo ""
  echo "Waiting for agents to initialize..."
  sleep 4
  echo ""
  _attach_or_hint
}

cmd_stop() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)

  # Parse flags AFTER _resolve_squad_name (which already consumed --name).
  local archive=true
  local nuke_worktrees=false
  for arg in "$@"; do
    case "$arg" in
      --no-archive) archive=false ;;
      --nuke-worktrees) nuke_worktrees=true ;;
    esac
  done

  # By default we KEEP worktrees on stop — they're a working copy of code and
  # the user may want them on resume. Pass --nuke-worktrees to discard them
  # (or use squad_worktree_cleanup directly after).
  if [[ -f "${squad_runtime}/session.json" ]] && $nuke_worktrees; then
    local session_id use_worktrees
    session_id=$(jq -r '.session_id' "${squad_runtime}/session.json" 2>/dev/null)
    use_worktrees=$(jq -r '.use_worktrees' "${squad_runtime}/session.json" 2>/dev/null)

    if [[ "$use_worktrees" == "true" ]] && [[ -n "$session_id" ]]; then
      echo "Removing worktrees (--nuke-worktrees)..."
      squad_worktree_cleanup "$REPO_PATH" "$session_id"
    fi
  fi

  # Kill tmux session
  squad_tmux_kill_session

  # Archive the runtime so the user can `squad resume` later. Skip with
  # --no-archive (which leaves the runtime dir in place, ready for the next
  # `squad start` to clobber).
  if $archive && [[ -d "$squad_runtime" ]] && [[ -f "${squad_runtime}/session.json" ]]; then
    local archive_path
    if archive_path=$(squad_archive_stash "$REPO_PATH" "$SQUAD_NAME"); then
      echo "Archived to ${archive_path}"
      echo "  → resume with: squad resume ${SQUAD_NAME}"
    else
      echo "Warning: failed to archive ${squad_runtime}; left in place" >&2
    fi

    # Lazy retention: prune anything past the cutoff.
    local pruned
    pruned=$(squad_archive_prune "$REPO_PATH")
    if [[ -n "$pruned" ]]; then
      local count
      count=$(printf '%s\n' "$pruned" | wc -l | tr -d ' ')
      echo "Pruned ${count} archive(s) older than ${SQUAD_ARCHIVE_RETENTION_DAYS}d"
    fi
  fi

  # If we just stopped the squad recorded in .squad/current, clear the pointer
  # so subsequent commands don't try to target a dead squad.
  if [[ -f "${REPO_PATH}/.squad/current" ]]; then
    local current
    current=$(<"${REPO_PATH}/.squad/current")
    if [[ "$current" == "$SQUAD_NAME" ]]; then
      rm -f "${REPO_PATH}/.squad/current"
    fi
  fi

  echo "Squad '${SQUAD_NAME}' stopped."
}

cmd_status() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)
  squad_monitor_status "$squad_runtime" "$REPO_PATH"
}

cmd_watch() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)
  # Strip --name from positional args so $1 is still the interval.
  local interval=5
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) shift 2 ;;
      *) interval="$1"; shift ;;
    esac
  done
  squad_monitor_watch "$squad_runtime" "$REPO_PATH" "$interval"
}

cmd_attach() {
  _resolve_squad_name "$@"
  squad_tmux_attach
}

cmd_roles() {
  echo "Available roles:"
  echo ""
  local _r_name _r_desc
  for role_file in "${SQUAD_DIR}/roles/"*.md; do
    if [[ -f "$role_file" ]]; then
      _r_name=$(basename "$role_file" .md)
      _r_desc=$(sed -n '3p' "$role_file" | sed 's/^[[:space:]]*//' | cut -c1-70)
      printf "  %-12s %s\n" "$_r_name" "${_r_desc:-$(head -1 "$role_file")}"
    fi
  done
  echo ""
  echo "Use: squad start --roles role1,role2,..."
}

cmd_init() {
  mkdir -p "${REPO_PATH}/sprints"
  cp "${SQUAD_DIR}/templates/sprint.md" "${REPO_PATH}/sprints/sprint-template.md"
  echo "Created sprints/sprint-template.md"
  echo "Edit the file and run: squad start sprints/sprint-template.md"
}

cmd_roster() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "No active squad '${SQUAD_NAME}' in ${REPO_PATH}" >&2
    exit 1
  fi
  squad_registry_roster_markdown "$squad_runtime"
}

# List all squads in the current repo. A squad is any subdirectory of
# .squad/ that has a session.json. Marks which one .squad/current points at
# and whether its tmux session is alive.
cmd_list() {
  local root="${REPO_PATH}/.squad"
  if [[ ! -d "$root" ]]; then
    echo "No squads in ${REPO_PATH}"
    return 0
  fi

  local current=""
  [[ -f "${root}/current" ]] && current=$(<"${root}/current")

  local found=false
  printf '%-3s  %-20s  %-8s  %-7s  %s\n' "" "NAME" "TMUX" "AGENTS" "STARTED"
  printf '%-3s  %-20s  %-8s  %-7s  %s\n' "" "----" "----" "------" "-------"

  local dir name marker tmux_status agents started session_name
  for dir in "$root"/*/; do
    [[ -d "$dir" ]] || continue
    [[ -f "${dir}session.json" ]] || continue
    found=true

    name=$(basename "$dir")
    marker=" "
    [[ "$name" == "$current" ]] && marker="*"

    session_name="claude-squad-${name}"
    if tmux has-session -t "$session_name" 2>/dev/null; then
      tmux_status="alive"
    else
      tmux_status="dead"
    fi

    agents=$(jq -r '[.agents[] | select(.status == "alive")] | length' \
      "${dir}session.json" 2>/dev/null || echo "?")
    started=$(jq -r '.start_time // .agents[0].spawned_at // "-"' \
      "${dir}session.json" 2>/dev/null)

    printf '%-3s  %-20s  %-8s  %-7s  %s\n' "$marker" "$name" "$tmux_status" "$agents" "$started"
  done

  if ! $found; then
    echo "No squads in ${REPO_PATH}"
    return 0
  fi

  echo ""
  echo "* = current squad (set by most recent 'squad start' or 'squad use')"
  echo "Use 'squad <command> --name <NAME>' to target a specific squad,"
  echo "or 'squad use <NAME>' to make it current for subsequent commands."
}

# Switch the .squad/current pointer to a given squad name. Read-only for
# the squad itself — only changes which squad subsequent commands target.
cmd_use() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Usage: squad use <name>" >&2
    exit 1
  fi
  local target="${REPO_PATH}/.squad/${name}/session.json"
  if [[ ! -f "$target" ]]; then
    echo "Error: no squad named '${name}' in ${REPO_PATH}" >&2
    echo "       Run 'squad list' to see available squads." >&2
    exit 1
  fi
  mkdir -p "${REPO_PATH}/.squad"
  printf '%s\n' "$name" > "${REPO_PATH}/.squad/current"
  echo "Current squad → ${name}"
}

# Acquire the spawn lock so two concurrent spawns can't pick the same instance.
# Returns 0 on success.
_spawn_lock_acquire() {
  local squad_dir="$1"
  local lockfile="${squad_dir}/spawn.lock"
  local max_wait=100  # 10s total
  local waited=0
  while ! mkdir "$lockfile" 2>/dev/null; do
    waited=$((waited + 1))
    if [[ $waited -ge $max_wait ]]; then
      rm -rf "$lockfile"
      mkdir "$lockfile" 2>/dev/null || return 1
      break
    fi
    sleep 0.1
  done
  return 0
}

_spawn_lock_release() {
  rm -rf "${1}/spawn.lock"
}

# squad spawn <role> [--instance N] [--worktree] [--no-worktree] [--model M] [--fresh] [--name <squad>]
cmd_spawn() {
  _resolve_squad_name "$@"

  local role=""
  local force_instance=""
  local worktree_flag=""     # "" = inherit session default; "1" = force on; "0" = force off
  local model_override=""
  local fresh=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)        shift 2 ;;  # already consumed by _resolve_squad_name
      --instance)    force_instance="$2"; shift 2 ;;
      --worktree)    worktree_flag="1"; shift ;;
      --no-worktree) worktree_flag="0"; shift ;;
      --model)       model_override="$2"; shift 2 ;;
      --fresh)       fresh=true; shift ;;
      -*)            echo "Unknown option: $1" >&2; exit 1 ;;
      *)             role="$1"; shift ;;
    esac
  done

  if [[ -z "$role" ]]; then
    echo "Usage: squad spawn <role> [--instance N] [--worktree|--no-worktree] [--model M] [--fresh] [--name <squad>]" >&2
    exit 1
  fi

  # Planner is a singleton — never spawn a second one.
  if [[ "$role" == "planner" ]]; then
    echo "Error: planner is a singleton — cannot be spawned again." >&2
    echo "       To restart the planner, run 'squad stop' and 'squad start'." >&2
    exit 1
  fi

  if ! validate_role "$role"; then
    echo "Error: unknown role '$role'. Run 'squad roles' to see available." >&2
    exit 1
  fi

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "Error: no active squad '${SQUAD_NAME}'. Run 'squad start' first." >&2
    exit 1
  fi
  if ! tmux has-session -t "$SQUAD_SESSION" 2>/dev/null; then
    echo "Error: tmux session '$SQUAD_SESSION' is not running." >&2
    exit 1
  fi

  local session_id session_model session_use_wt session_sprint
  session_id=$(jq -r '.session_id' "${squad_runtime}/session.json")
  session_model=$(jq -r '.model' "${squad_runtime}/session.json")
  session_use_wt=$(jq -r '.use_worktrees' "${squad_runtime}/session.json")
  session_sprint=$(jq -r '.sprint_file // ""' "${squad_runtime}/session.json")

  local model="${model_override:-$session_model}"
  local use_wt="$session_use_wt"
  [[ "$worktree_flag" == "1" ]] && use_wt="true"
  [[ "$worktree_flag" == "0" ]] && use_wt="false"

  _spawn_lock_acquire "$squad_runtime" || { echo "Error: spawn lock timeout" >&2; exit 1; }

  # Decide instance number. By default reuse the lowest free slot ≥1 so a
  # killed coder-2 resumes as coder-2 (handoff filenames line up).
  local instance="$force_instance"
  if [[ -z "$instance" ]]; then
    instance=$(_next_free_instance "$squad_runtime" "$role")
  fi
  local name="$role"
  [[ "$instance" -gt 1 ]] && name="${role}-${instance}"

  # Refuse to spawn a duplicate alive instance.
  local existing_pane
  existing_pane=$(squad_tmux_pane_for_name "$name")
  if [[ -n "$existing_pane" ]]; then
    _spawn_lock_release "$squad_runtime"
    echo "Error: ${name} is already alive in pane ${existing_pane}." >&2
    exit 1
  fi

  # Detect resurrection: is there a prior killed/vanished entry for this name?
  local prior
  prior=$(squad_registry_get "$squad_runtime" "$name")
  local prior_status=""
  local prior_session_id=""
  if [[ -n "$prior" ]]; then
    prior_status=$(echo "$prior" | jq -r '.status')
    prior_session_id=$(echo "$prior" | jq -r '.claude_session_id // ""')
  fi
  local is_resurrection=false
  if [[ -n "$prior" ]] && [[ "$prior_status" != "alive" ]] && ! $fresh; then
    is_resurrection=true
  fi

  # --fresh: archive the prior handoff so the new agent starts blank.
  if $fresh && [[ -f "${squad_runtime}/handoff-${name}.md" ]]; then
    local ts
    ts=$(date -u +%s)
    mv "${squad_runtime}/handoff-${name}.md" "${squad_runtime}/handoff-${name}.archived-${ts}.md"
    echo "  Archived prior handoff to handoff-${name}.archived-${ts}.md"
  fi

  # Claude session id. Resurrection reuses the prior id; everything else gets
  # a freshly-generated UUID assigned at spawn time so we own the identifier.
  local claude_session_id
  if $is_resurrection && [[ -n "$prior_session_id" ]]; then
    claude_session_id="$prior_session_id"
    echo "  Resurrecting ${name} with Claude session ${claude_session_id}"
  else
    claude_session_id=$(uuidgen | tr 'A-Z' 'a-z')
  fi

  # Worktree (reuse if already present from a prior life).
  local work_dir="$REPO_PATH"
  local wt_path=""
  if [[ "$use_wt" == "true" ]]; then
    wt_path=$(squad_worktree_path "$name" "$session_id")
    if [[ -d "$wt_path" ]]; then
      echo "  Reusing existing worktree at $wt_path"
    else
      wt_path=$(squad_worktree_create "$REPO_PATH" "$name" "$session_id")
    fi
    if [[ -n "$wt_path" ]] && [[ -d "$wt_path" ]]; then
      work_dir="$wt_path"
    else
      echo "  Warning: failed to create worktree; falling back to repo root" >&2
      wt_path=""
    fi
  fi

  squad_prompt_generate_dynamic "$squad_runtime" "$name" "$role" "$work_dir" "$session_sprint" >/dev/null

  local resume_flag="0"
  $is_resurrection && resume_flag="1"
  squad_prompt_launcher_dynamic "$squad_runtime" "$name" "$work_dir" "$model" "$claude_session_id" "$resume_flag" >/dev/null

  local pane_id
  pane_id=$(squad_tmux_spawn "$role" "$instance" "bash ${squad_runtime}/launch-${name}.sh")

  # Drop any prior entry for this name (killed/vanished) so the registry has
  # exactly one row per name reflecting the current alive state.
  if [[ -n "$prior" ]]; then
    squad_registry_remove "$squad_runtime" "$name"
  fi

  local agent_json
  agent_json=$(jq -n \
    --arg role "$role" --argjson instance "$instance" --arg name "$name" \
    --arg pane_id "$pane_id" --arg wt "$wt_path" --arg model "$model" \
    --arg claude_sid "$claude_session_id" \
    --arg spawned_at "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
    '{role:$role, instance:$instance, name:$name, pane_id:$pane_id,
      worktree_path:$wt, model:$model, claude_session_id:$claude_sid,
      spawned_at:$spawned_at, status:"alive"}')
  squad_registry_add "$squad_runtime" "$agent_json"

  squad_mailbox_send "$squad_runtime" "system" "all" "agent_spawned" \
    "{\"name\":\"${name}\",\"role\":\"${role}\",\"pane_id\":\"${pane_id}\",\"claude_session_id\":\"${claude_session_id}\",\"resumed\":${is_resurrection}}"

  _spawn_lock_release "$squad_runtime"

  if $is_resurrection; then
    echo "Resurrected ${name} (${pane_id}) in ${work_dir} — Claude conversation resumed."
  else
    echo "Spawned ${name} (${pane_id}) in ${work_dir}"
  fi
}

# Pick an instance number for spawning a new agent of <role>.
#
# Policy: prefer to RESURRECT the lowest-numbered killed/vanished slot for
# this role (so kill+respawn of "coder" comes back as "coder", not "coder-2",
# and its handoff filename + worktree line up). Only climb to a brand-new
# instance when no resurrectable slot exists or all prior instances are alive.
_next_free_instance() {
  local squad_dir="$1"
  local role="$2"

  # Instances currently alive in tmux for this role.
  local alive
  alive=$(tmux list-panes -t "$SQUAD_SESSION" \
    -F '#{@agent_role} #{@agent_instance}' 2>/dev/null \
    | awk -v r="$role" '$1==r {print $2}' | sort -un)

  # Lowest killed/vanished instance whose number isn't currently alive.
  local resurrectable
  resurrectable=$(jq -r --arg role "$role" '
    .agents
    | map(select(.role == $role and (.status == "killed" or .status == "vanished")))
    | sort_by(.instance) | .[0].instance // empty
  ' "${squad_dir}/session.json" 2>/dev/null)
  if [[ -n "$resurrectable" ]] && ! echo "$alive" | grep -qx "$resurrectable"; then
    echo "$resurrectable"
    return
  fi

  # No resurrectable slot — climb to the next unused number.
  local i=1
  while echo "$alive" | grep -qx "$i"; do
    i=$((i + 1))
  done
  echo "$i"
}

# squad kill <name> [--hard] [--grace-seconds N] [--name <squad>]
cmd_kill() {
  _resolve_squad_name "$@"

  local name=""
  local hard=false
  local grace=10

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)           shift 2 ;;  # consumed by _resolve_squad_name
      --hard)           hard=true; shift ;;
      --grace-seconds)  grace="$2"; shift 2 ;;
      -*)               echo "Unknown option: $1" >&2; exit 1 ;;
      *)                name="$1"; shift ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "Usage: squad kill <name> [--hard] [--grace-seconds N] [--name <squad>]" >&2
    exit 1
  fi

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "Error: no active squad '${SQUAD_NAME}'." >&2
    exit 1
  fi
  if ! tmux has-session -t "$SQUAD_SESSION" 2>/dev/null; then
    echo "Error: tmux session '$SQUAD_SESSION' is not running." >&2
    exit 1
  fi

  local pane_id
  pane_id=$(squad_tmux_pane_for_name "$name")
  if [[ -z "$pane_id" ]]; then
    echo "No alive agent named '${name}'."
    exit 0
  fi

  # Last-pane guard: killing the only pane ends the tmux session entirely.
  local live
  live=$(squad_tmux_pane_count_live)
  if [[ "$live" -le 1 ]]; then
    echo "Error: '${name}' is the only pane left. Use 'squad stop' to end the session." >&2
    exit 1
  fi

  local handoff="${squad_runtime}/handoff-${name}.md"

  if ! $hard; then
    # Soft path: announce, give the agent a grace window to flush handoff.
    squad_mailbox_send "$squad_runtime" "system" "all" "agent_closing" \
      "{\"name\":\"${name}\",\"pane_id\":\"${pane_id}\",\"grace_seconds\":${grace},\"handoff\":\"${handoff}\"}"

    # Also poke the agent's own pane with a soft notice so it can flush even
    # if it's mid-task and hasn't checked the mailbox yet.
    tmux send-keys -t "$pane_id" "# RETIRING in ${grace}s — please finalize ${handoff} now" Enter 2>/dev/null || true

    echo "Sent agent_closing for ${name}; waiting ${grace}s grace..."
    sleep "$grace"
  fi

  squad_tmux_kill_pane "$pane_id"
  squad_registry_mark_killed "$squad_runtime" "$name" "$handoff"

  squad_mailbox_send "$squad_runtime" "system" "all" "agent_closed" \
    "{\"name\":\"${name}\",\"handoff\":\"${handoff}\"}"

  echo "Killed ${name} (${pane_id})."
}

# squad doctor — reconcile registry vs tmux. Flips orphans to vanished.
cmd_doctor() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "No active squad '${SQUAD_NAME}' in ${REPO_PATH}" >&2
    exit 1
  fi

  local alive_in_tmux alive_in_registry vanished_count=0
  alive_in_tmux=$(squad_tmux_list_agents | awk -F'\t' '{print $1}' | sort -u)
  alive_in_registry=$(jq -r '.agents[] | select(.status == "alive") | .name + "|" + .pane_id' \
    "${squad_runtime}/session.json" 2>/dev/null)

  local name pane_id
  while IFS='|' read -r name pane_id; do
    [[ -z "$name" ]] && continue
    if ! echo "$alive_in_tmux" | grep -qx "$pane_id"; then
      squad_registry_mark_vanished "$squad_runtime" "$name"
      squad_mailbox_send "$squad_runtime" "system" "all" "agent_vanished" \
        "{\"name\":\"${name}\",\"pane_id\":\"${pane_id}\"}"
      echo "  ${name} (${pane_id}) → vanished"
      vanished_count=$((vanished_count + 1))
    fi
  done <<< "$alive_in_registry"

  if [[ "$vanished_count" -eq 0 ]]; then
    echo "Registry and tmux agree. No orphans."
  else
    echo "Reconciled ${vanished_count} orphan(s)."
  fi
}

# squad usage <name>
# Reads the Claude session log for an agent and prints a JSON object the
# planner can pipe through jq:
#   { name, status, alive_seconds, tokens_in, tokens_out, tokens_cache_read,
#     tokens_cache_create, tokens_total, mailbox_sent, mailbox_received }
#
# This is a MECHANISM. It does not interpret the numbers or decide anything.
# The planner reads it and makes its own judgment about recycling.
cmd_usage() {
  _resolve_squad_name "$@"

  local name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) shift 2 ;;  # consumed
      -*)     echo "Unknown option: $1" >&2; exit 1 ;;
      *)      name="$1"; shift ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "Usage: squad usage <agent-name> [--name <squad>]" >&2
    exit 1
  fi

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "Error: no active squad '${SQUAD_NAME}'." >&2
    exit 1
  fi

  local agent
  agent=$(squad_registry_get "$squad_runtime" "$name")
  if [[ -z "$agent" ]]; then
    echo "Error: no agent named '${name}' in registry." >&2
    exit 1
  fi

  local claude_sid status spawned_at work_dir
  claude_sid=$(echo "$agent" | jq -r '.claude_session_id // ""')
  status=$(echo "$agent" | jq -r '.status')
  spawned_at=$(echo "$agent" | jq -r '.spawned_at')
  work_dir=$(echo "$agent" | jq -r '.worktree_path // ""')
  [[ -z "$work_dir" ]] && work_dir="$REPO_PATH"

  # Claude stores logs under ~/.claude/projects/<encoded-repo-path>/<sid>.jsonl
  # The path encoding swaps slashes for hyphens and prepends a leading hyphen.
  local encoded
  encoded=$(echo "$work_dir" | sed 's|/|-|g')
  local log_file="$HOME/.claude/projects/${encoded}/${claude_sid}.jsonl"

  local tokens_in=0 tokens_out=0 tokens_cache_read=0 tokens_cache_create=0
  if [[ -n "$claude_sid" ]] && [[ -f "$log_file" ]]; then
    # Sum every usage block in the session log.
    local sums
    sums=$(jq -s '
      [.[] | select(.message.usage?) | .message.usage]
      | {
          in:   (map(.input_tokens // 0)               | add // 0),
          out:  (map(.output_tokens // 0)              | add // 0),
          cr:   (map(.cache_read_input_tokens // 0)    | add // 0),
          cc:   (map(.cache_creation_input_tokens // 0)| add // 0)
        }' "$log_file" 2>/dev/null)
    if [[ -n "$sums" ]]; then
      tokens_in=$(echo   "$sums" | jq -r '.in')
      tokens_out=$(echo  "$sums" | jq -r '.out')
      tokens_cache_read=$(echo "$sums" | jq -r '.cr')
      tokens_cache_create=$(echo "$sums" | jq -r '.cc')
    fi
  fi

  local tokens_total=$((tokens_in + tokens_out + tokens_cache_read + tokens_cache_create))

  # Wall time alive (seconds since spawn).
  local alive_seconds=0
  if [[ -n "$spawned_at" ]]; then
    local now spawn_epoch
    now=$(date -u +%s)
    # macOS BSD date: -j -f for parsing.
    spawn_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$spawned_at" +%s 2>/dev/null \
                  || date -u -d "$spawned_at" +%s 2>/dev/null \
                  || echo "$now")
    alive_seconds=$((now - spawn_epoch))
  fi

  # Mailbox activity counts.
  local mailbox="${squad_runtime}/mailbox.jsonl"
  local mailbox_sent=0 mailbox_received=0
  if [[ -f "$mailbox" ]]; then
    mailbox_sent=$(jq -c --arg name "$name" 'select(.from == $name)' "$mailbox" 2>/dev/null | wc -l | tr -d ' ')
    mailbox_received=$(jq -c --arg name "$name" 'select(.to == $name or .to == "all")' "$mailbox" 2>/dev/null | wc -l | tr -d ' ')
  fi

  jq -n \
    --arg name "$name" --arg status "$status" \
    --arg sid "$claude_sid" --arg log "$log_file" \
    --argjson alive "$alive_seconds" \
    --argjson tin "$tokens_in" --argjson tout "$tokens_out" \
    --argjson tcr "$tokens_cache_read" --argjson tcc "$tokens_cache_create" \
    --argjson ttot "$tokens_total" \
    --argjson msent "$mailbox_sent" --argjson mrecv "$mailbox_received" \
    '{
      name: $name,
      status: $status,
      claude_session_id: $sid,
      session_log: $log,
      alive_seconds: $alive,
      tokens_in: $tin,
      tokens_out: $tout,
      tokens_cache_read: $tcr,
      tokens_cache_create: $tcc,
      tokens_total: $ttot,
      mailbox_sent: $msent,
      mailbox_received: $mrecv
    }'
}

# Send a message to another agent and nudge their pane.
# Sender is taken from $SQUAD_AGENT_NAME (exported into each pane by the launcher).
# Recipient is resolved against the live registry; `all` broadcasts to every
# alive agent except the sender. Falls back to mailbox-only write if the
# recipient has no pane (e.g., killed or not yet spawned).
#
# Usage: squad mail <to_name> <type> <body...>
cmd_mail() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)

  local from="${SQUAD_AGENT_NAME:-}"
  if [[ -z "$from" ]]; then
    echo "Error: \$SQUAD_AGENT_NAME is not set. Run this from inside a squad agent pane, or export SQUAD_AGENT_NAME first." >&2
    return 1
  fi

  local to="${1:-}"
  local msg_type="${2:-}"
  shift 2 2>/dev/null || true
  local body="$*"

  if [[ -z "$to" || -z "$msg_type" || -z "$body" ]]; then
    echo "Usage: squad mail <to_name> <type> <body...>" >&2
    return 1
  fi

  squad_mailbox_send "$squad_runtime" "$from" "$to" "$msg_type" "$body"

  local session_file="${squad_runtime}/session.json"
  if [[ ! -f "$session_file" ]]; then
    return 0
  fi

  if [[ "$to" == "all" ]]; then
    # Nudge every alive agent except the sender.
    local pid
    while IFS= read -r pid; do
      [[ -n "$pid" ]] || continue
      squad_tmux_nudge_pane "$pid" "$from" "$msg_type"
    done < <(jq -r --arg me "$from" '
      .agents[]
      | select(.status == "alive" and .name != $me)
      | .pane_id
    ' "$session_file")
  else
    local pane_id
    pane_id=$(jq -r --arg name "$to" '
      .agents[] | select(.name == $name and .status == "alive") | .pane_id
    ' "$session_file")
    if [[ -n "$pane_id" && "$pane_id" != "null" ]]; then
      squad_tmux_nudge_pane "$pane_id" "$from" "$msg_type"
    else
      echo "Note: recipient '${to}' has no live pane — message queued in mailbox only." >&2
    fi
  fi
}

# Show mail addressed to the caller (or to `all`).
# Usage: squad inbox [--since <iso-timestamp>] [--all] [--name <override>]
cmd_inbox() {
  _resolve_squad_name "$@"
  local squad_runtime
  squad_runtime=$(_squad_runtime)

  local who="${SQUAD_AGENT_NAME:-}"
  local since=""
  local show_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since) since="$2"; shift 2 ;;
      --all)   show_all=1; shift ;;
      --name)  who="$2"; shift 2 ;;
      --name=*) who="${1#--name=}"; shift ;;
      *)       shift ;;
    esac
  done

  if [[ -z "$who" ]]; then
    echo "Error: cannot determine inbox owner. Pass --name <agent> or run from inside a squad pane." >&2
    return 1
  fi

  local mailbox="${squad_runtime}/mailbox.jsonl"
  if [[ ! -f "$mailbox" ]]; then
    return 0
  fi

  local filter='select(.to == $me or .to == "all")'
  if [[ "$show_all" == "1" ]]; then
    filter='.'
  fi
  if [[ -n "$since" ]]; then
    filter="${filter} | select(.ts > \$since)"
  fi

  jq -c --arg me "$who" --arg since "$since" "$filter" "$mailbox"
}

# squad resume [name] [--fresh] [--no-restore-claude]
# Restore the most recent archive matching <name> (default: "default") and
# respawn each previously-alive agent with --resume on their original Claude
# session id. Refuses if a live squad with the target name already exists.
#
# Flags:
#   --fresh               start each agent with a fresh Claude conversation
#                         (handoff files archived) — useful if the prior
#                         context is stale.
#   --no-restore-claude   don't pass --resume to Claude; still respawn the
#                         topology and pick up handoff files. Lighter weight
#                         than --fresh (handoffs preserved, just no chat).
cmd_resume() {
  local name=""
  local fresh=false
  local restore_claude=true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fresh)              fresh=true; shift ;;
      --no-restore-claude)  restore_claude=false; shift ;;
      --name)               name="$2"; shift 2 ;;  # alias for positional
      -*)                   echo "Unknown option: $1" >&2; exit 1 ;;
      *)                    name="$1"; shift ;;
    esac
  done
  [[ -z "$name" ]] && name="default"

  local archive_dir
  if ! archive_dir=$(squad_archive_latest "$REPO_PATH" "$name"); then
    echo "Error: no archive matching '${name}' in $(squad_archive_dir "$REPO_PATH")" >&2
    echo "       Run 'squad archive list' to see what's available." >&2
    exit 1
  fi

  # Resolve target name (an archive's meta.json holds the original squad name,
  # which is what we restore to — not the timestamped archive basename).
  local target_name
  target_name=$(jq -r '.name' "${archive_dir}/meta.json" 2>/dev/null)
  [[ -z "$target_name" || "$target_name" == "null" ]] && target_name="$name"

  # Refuse if a live squad with that name already exists.
  if [[ -d "${REPO_PATH}/.squad/${target_name}" ]] || \
     tmux has-session -t "claude-squad-${target_name}" 2>/dev/null; then
    echo "Error: squad '${target_name}' is already active." >&2
    echo "       Run 'squad stop --name ${target_name}' first, then resume." >&2
    exit 1
  fi

  echo "Resuming squad '${target_name}' from ${archive_dir}"
  echo "  archived at: $(jq -r '.archived_at' "${archive_dir}/meta.json" 2>/dev/null)"

  # Lazy retention prune while we're here.
  squad_archive_prune "$REPO_PATH" >/dev/null

  local squad_runtime
  squad_runtime=$(squad_archive_restore "$REPO_PATH" "$archive_dir" "$target_name") || exit 1

  # Make the resumed squad the current one for subsequent commands.
  SQUAD_NAME="$target_name"
  export SQUAD_NAME
  squad_tmux_set_session_name
  mkdir -p "${REPO_PATH}/.squad"
  printf '%s\n' "$SQUAD_NAME" > "${REPO_PATH}/.squad/current"

  # Snapshot the previously-alive roster BEFORE we mutate anything. Order:
  # planner first, then everyone else, so the spawn helpers can split off
  # planner's pane.
  local roster_json
  roster_json=$(jq -c '
    [.agents[] | select(.status == "alive")]
    | sort_by(if .role == "planner" then 0 else 1 end, .instance)
  ' "${squad_runtime}/session.json")

  local prev_count
  prev_count=$(echo "$roster_json" | jq 'length')
  if [[ "$prev_count" == "0" ]]; then
    echo "Warning: archive had no alive agents; restoring runtime only (no tmux session)" >&2
    return 0
  fi

  # Mark every prior-alive entry as 'archived' so the registry is clean;
  # spawning each agent below will add a fresh alive row.
  local tmp="${squad_runtime}/session.json.tmp"
  jq '.agents |= map(if .status == "alive" then .status = "archived" else . end)' \
    "${squad_runtime}/session.json" > "$tmp" && mv "$tmp" "${squad_runtime}/session.json"

  local session_id session_model session_use_wt session_sprint
  session_id=$(jq -r '.session_id' "${squad_runtime}/session.json")
  session_model=$(jq -r '.model' "${squad_runtime}/session.json")
  session_use_wt=$(jq -r '.use_worktrees' "${squad_runtime}/session.json")
  session_sprint=$(jq -r '.sprint_file // ""' "${squad_runtime}/session.json")

  # First agent: re-create the tmux session anchored on it. We bypass the
  # high-level cmd_spawn and replicate its plumbing so we can target either
  # `squad_tmux_create_single_pane` (first agent) or `squad_tmux_spawn`
  # (subsequent agents) as needed.
  local i=0
  while IFS= read -r agent; do
    [[ -n "$agent" ]] || continue

    local role instance name pane_id wt_path agent_model claude_sid
    role=$(echo "$agent" | jq -r '.role')
    instance=$(echo "$agent" | jq -r '.instance')
    name=$(echo "$agent" | jq -r '.name')
    wt_path=$(echo "$agent" | jq -r '.worktree_path // ""')
    agent_model=$(echo "$agent" | jq -r ".model // \"${session_model}\"")
    claude_sid=$(echo "$agent" | jq -r '.claude_session_id // ""')

    local work_dir="$REPO_PATH"
    if [[ -n "$wt_path" && -d "$wt_path" ]]; then
      work_dir="$wt_path"
    elif [[ -n "$wt_path" ]]; then
      echo "  Warning: ${name}'s worktree ${wt_path} is missing; falling back to repo root" >&2
      wt_path=""
    fi

    # --fresh: archive the prior handoff so the agent starts blank, and
    # generate a brand new Claude session.
    if $fresh && [[ -f "${squad_runtime}/handoff-${name}.md" ]]; then
      local ts
      ts=$(date -u +%s)
      mv "${squad_runtime}/handoff-${name}.md" "${squad_runtime}/handoff-${name}.archived-${ts}.md"
    fi

    local resume_flag="0"
    if $restore_claude && ! $fresh && [[ -n "$claude_sid" && "$claude_sid" != "null" ]]; then
      resume_flag="1"
    else
      claude_sid=$(uuidgen | tr 'A-Z' 'a-z')
    fi

    squad_prompt_generate_dynamic "$squad_runtime" "$name" "$role" "$work_dir" "$session_sprint" >/dev/null
    squad_prompt_launcher_dynamic "$squad_runtime" "$name" "$work_dir" "$agent_model" "$claude_sid" "$resume_flag" >/dev/null

    if [[ "$i" == "0" ]]; then
      pane_id=$(squad_tmux_create_single_pane "$role" "$instance")
      squad_tmux_launch_pane "$pane_id" "bash ${squad_runtime}/launch-${name}.sh"
    else
      pane_id=$(squad_tmux_spawn "$role" "$instance" "bash ${squad_runtime}/launch-${name}.sh")
    fi

    # Replace the old archived row (or add a fresh one if none existed).
    squad_registry_remove "$squad_runtime" "$name"
    local agent_json
    agent_json=$(jq -n \
      --arg role "$role" --argjson instance "$instance" --arg name "$name" \
      --arg pane_id "$pane_id" --arg wt "$wt_path" --arg model "$agent_model" \
      --arg claude_sid "$claude_sid" \
      --arg spawned_at "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
      '{role:$role, instance:$instance, name:$name, pane_id:$pane_id,
        worktree_path:$wt, model:$model, claude_session_id:$claude_sid,
        spawned_at:$spawned_at, status:"alive"}')
    squad_registry_add "$squad_runtime" "$agent_json"

    echo "  Resumed ${name} (${pane_id}) in ${work_dir}"
    i=$((i + 1))
  done < <(echo "$roster_json" | jq -c '.[]')

  squad_mailbox_send "$squad_runtime" "system" "all" "squad_resumed" \
    "{\"squad\":\"${target_name}\",\"agents\":${prev_count},\"archived_at\":\"$(jq -r '.archived_at' "${squad_runtime}/meta.json" 2>/dev/null || echo unknown)\"}"

  echo ""
  echo "Squad '${target_name}' resumed with ${prev_count} agent(s)."
  echo "Run 'squad attach' to jump into the session."
}

# squad archive <subcommand>
#   list                          show all archived squads (newest first)
#   prune [--older-than 30d]      delete archives older than N days
#   rm <archive-dir>              delete a specific archive
cmd_archive() {
  local sub="${1:-list}"
  shift 2>/dev/null || true

  case "$sub" in
    list|ls)
      _cmd_archive_list "$@"
      ;;
    prune|gc)
      local days="$SQUAD_ARCHIVE_RETENTION_DAYS"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --older-than)
            # Accept "30d", "30", "720h" — we only honor days for now.
            days="${2%d}"
            days="${days%h}"
            shift 2
            ;;
          *) shift ;;
        esac
      done
      local pruned
      pruned=$(squad_archive_prune "$REPO_PATH" "$days")
      if [[ -z "$pruned" ]]; then
        echo "Nothing to prune (cutoff: ${days}d)."
      else
        local count
        count=$(printf '%s\n' "$pruned" | wc -l | tr -d ' ')
        echo "Pruned ${count} archive(s) older than ${days}d:"
        printf '  %s\n' $pruned
      fi
      ;;
    rm|remove)
      local target="${1:-}"
      if [[ -z "$target" ]]; then
        echo "Usage: squad archive rm <archive-dir-or-basename>" >&2
        exit 1
      fi
      local arch_root
      arch_root=$(squad_archive_dir "$REPO_PATH")
      # Allow either a full path or a basename inside .squad-archive/
      local full="$target"
      [[ -d "$target" ]] || full="${arch_root}/${target}"
      if [[ ! -d "$full" ]]; then
        echo "Error: archive not found: ${target}" >&2
        exit 1
      fi
      rm -rf "$full"
      echo "Removed ${full}"
      ;;
    *)
      echo "Usage: squad archive {list|prune|rm}" >&2
      exit 1
      ;;
  esac
}

_cmd_archive_list() {
  local rows
  rows=$(squad_archive_list "$REPO_PATH")
  if [[ -z "$rows" ]]; then
    echo "No archives in $(squad_archive_dir "$REPO_PATH")"
    return 0
  fi
  printf '%-20s  %-22s  %-8s  %-6s  %s\n' "NAME" "ARCHIVED" "AGE" "AGENTS" "DESCRIPTION"
  printf '%-20s  %-22s  %-8s  %-6s  %s\n' "----" "--------" "---" "------" "-----------"
  local dir name archived age agents desc
  while IFS=$'\t' read -r dir name archived age agents desc; do
    printf '%-20s  %-22s  %-8s  %-6s  %s\n' "$name" "$archived" "$age" "$agents" "${desc:--}"
  done <<< "$rows"
  echo ""
  echo "Resume the latest archive of a squad: squad resume <name>"
  echo "Retention: archives older than ${SQUAD_ARCHIVE_RETENTION_DAYS}d are auto-pruned."
}

# this is a "context refresh after fatigue" verb. Pass --fresh to start with
# a brand-new Claude session.
cmd_recycle() {
  _resolve_squad_name "$@"

  local name=""
  local reason=""
  local grace="10"
  local fresh_flag=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)           shift 2 ;;  # consumed
      --reason)         reason="$2"; shift 2 ;;
      --grace-seconds)  grace="$2"; shift 2 ;;
      --fresh)          fresh_flag="--fresh"; shift ;;
      -*)               echo "Unknown option: $1" >&2; exit 1 ;;
      *)                name="$1"; shift ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "Usage: squad recycle <name> [--reason \"...\"] [--grace-seconds N] [--fresh] [--name <squad>]" >&2
    exit 1
  fi

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "Error: no active squad '${SQUAD_NAME}'." >&2
    exit 1
  fi

  local prior
  prior=$(squad_registry_get "$squad_runtime" "$name")
  if [[ -z "$prior" ]]; then
    echo "Error: no agent named '${name}' in registry." >&2
    exit 1
  fi

  local role
  role=$(echo "$prior" | jq -r '.role')

  # Broadcast the recycle intent up front so peers see WHY this is happening.
  squad_mailbox_send "$squad_runtime" "system" "all" "recycling" \
    "{\"name\":\"${name}\",\"reason\":\"${reason}\",\"grace_seconds\":${grace},\"fresh\":$([ -n "$fresh_flag" ] && echo true || echo false)}"

  echo "Recycling ${name}${reason:+ — reason: ${reason}}"
  # Pass --name through to nested calls so they target the same squad even
  # when .squad/current points at a different one.
  cmd_kill --name "$SQUAD_NAME" "$name" --grace-seconds "$grace"
  # cmd_kill exits on error; if we got here it succeeded.

  if [[ -n "$fresh_flag" ]]; then
    cmd_spawn --name "$SQUAD_NAME" "$role" --instance "$(echo "$prior" | jq -r '.instance')" $fresh_flag
  else
    cmd_spawn --name "$SQUAD_NAME" "$role" --instance "$(echo "$prior" | jq -r '.instance')"
  fi
}

cmd_harness() {
  local prompt="${1:-}"
  local model="${2:-claude-opus-4-6}"

  if [[ -z "$prompt" ]]; then
    echo "Usage: squad harness \"Build a ...\" [model]" >&2
    exit 1
  fi

  squad_harness_run "$prompt" "$REPO_PATH" "$model"
}

cmd_merge() {
  _resolve_squad_name "$@"

  local role=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) shift 2 ;;  # consumed
      -*)     echo "Unknown option: $1" >&2; exit 1 ;;
      *)      role="$1"; shift ;;
    esac
  done

  if [[ -z "$role" ]]; then
    echo "Usage: squad merge <role> [--name <squad>]" >&2
    exit 1
  fi

  local squad_runtime
  squad_runtime=$(_squad_runtime)
  if [[ ! -f "${squad_runtime}/session.json" ]]; then
    echo "Error: no active squad '${SQUAD_NAME}' found." >&2
    exit 1
  fi

  local session_id target_branch
  session_id=$(jq -r '.session_id' "${squad_runtime}/session.json")
  target_branch=$(git -C "$REPO_PATH" branch --show-current)

  echo "Merging $role's worktree branch into $target_branch..."
  squad_worktree_merge "$REPO_PATH" "$role" "$session_id" "$target_branch"
  echo "Done."
}

# ─── Main ────────────────────────────────────────────────────────

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    start)    cmd_start "$@" ;;
    stop)     cmd_stop "$@" ;;
    status)   cmd_status "$@" ;;
    watch)    cmd_watch "$@" ;;
    attach)   cmd_attach "$@" ;;
    roles)    cmd_roles ;;
    roster)   cmd_roster "$@" ;;
    list|ls)  cmd_list ;;
    use)      cmd_use "$@" ;;
    spawn)    cmd_spawn "$@" ;;
    kill)     cmd_kill "$@" ;;
    doctor)   cmd_doctor "$@" ;;
    usage)    cmd_usage "$@" ;;
    recycle)  cmd_recycle "$@" ;;
    mail)     cmd_mail "$@" ;;
    inbox)    cmd_inbox "$@" ;;
    resume)   cmd_resume "$@" ;;
    archive)  cmd_archive "$@" ;;
    init)     cmd_init ;;
    harness)  cmd_harness "$@" ;;
    merge)    cmd_merge "$@" ;;
    help|-h|--help)
      usage
      ;;
    version|--version|-v)
      echo "Claude Squad v${SQUAD_VERSION}"
      ;;
    *)
      echo "Unknown command: $command" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
